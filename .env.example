TELEGRAM_BOT_TOKEN=your_bot_token
# Опционально: chat_id для алерта при расхождении WB после полного синка (см. /sync_full и таймер).
TELEGRAM_ADMIN_CHAT_ID=
RESERVE_INTERVAL_SECONDS=120
# 1 = пушить остатки на маркетплейсы (по умолчанию), 0 = полностью отключить пуш остатков.
# Резервы/заказы и остальные функции бота/веба при 0 продолжают работать.
STOCK_SYNC_ENABLED=1
DB_URL=sqlite:///crm_bot.db
# Журнал перемещений остатков (отдельный файл SQLite)
MOVEMENT_DB_URL=sqlite:///movements.db
DEFAULT_STOCKS_SHEET_URL=
# Таблица bot_table: остатки, movement и лист assembly (маршрут ТСД для FBS Ozon).
# Лист assembly ищется по имени FBS_ASSEMBLY_SHEET_NAME, gid из этой ссылки не используется.
# Google Таблица для записи листов «FBS список+дата» (/ozon_labels) — отдельная от bot_table.
FBS_LIST_SHEET_URL=
# Лист-шаблон в этой таблице (копируется целиком, затем заполняются артикул / кол-во / отправление).
FBS_LIST_TEMPLATE_SHEET=FBSTemplate
# Лист со сборочным заданием ТСД в bot_table (DEFAULT_STOCKS_SHEET_URL); порядок FBS-списка Ozon.
# Обычно оставьте assembly: это имя вкладки. gid используйте только если явно нужен конкретный лист.
FBS_ASSEMBLY_SHEET_NAME=assembly
# Альтернатива имени — числовой gid вкладки. Если задан, он имеет приоритет над именем.
FBS_ASSEMBLY_SHEET_GID=
# JSON service account (доступ «Редактор» к DEFAULT_STOCKS_SHEET_URL и FBS_LIST_SHEET_URL).
GOOGLE_SERVICE_ACCOUNT_FILE=
# Поворот PDF-этикеток Ozon: 90 (по умолчанию), -90 или 0 = не крутить.
OZON_LABEL_ROTATE_DEGREES=90
# Yandex FBS (/yandex_labels): формат этикетки A9_HORIZONTALLY, A9, A7, A4.
YANDEX_LABEL_FORMAT=A9_HORIZONTALLY
YANDEX_LABEL_ROTATE_DEGREES=0

OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
OZON_WAREHOUSE_ID=1020005014123930
# Период в днях для /ozon_analytics если не передан аргумент
OZON_ANALYTICS_PERIOD_DAYS=30

WB_API_TOKEN=your_wb_token
# Seller warehouse id from GET https://marketplace-api.wildberries.ru/api/v3/warehouses (field `id`), not officeId/JWT oid.
WB_WAREHOUSE_ID=your_wb_warehouse_id
# Optional: токен с правом «Контент» для сопоставления артикулов с chrtId. Пусто = тот же WB_API_TOKEN.
WB_CONTENT_TOKEN=
# Полный синк каждого маркетплейса (сверка резервов) не реже чем раз в N секунд. Между полными — дельта (WB — узкое окно по API; Ozon/Yandex — тот же запрос, но без reconcile).
FULL_SYNC_INTERVAL_SECONDS=3600
# Совместимость: при отсутствии FULL_SYNC_INTERVAL_SECONDS читается WB_FULL_SYNC_INTERVAL_SECONDS.

YANDEX_CAMPAIGN_ID=your_yandex_campaign_id
YANDEX_API_KEY=your_yandex_api_key

# Веб-панель: python run_web.py. WEB_DASHBOARD_SECRET — обязательный пароль для входа в панель (не пустой).
WEB_DASHBOARD_SECRET=change_me_to_a_long_random_string
WEB_HOST=127.0.0.1
# Если при запуске run_web ошибка «порт занят» — закройте старый экземпляр или смените порт.
WEB_PORT=8765

# Локальный агент тихой печати штрихкодов (start_barcode_print_agent.bat на ПК с принтером):
# Если агент запущен на другом ПК, укажите IP этого ПК, например 192.168.1.50.
# BARCODE_PRINT_AGENT_HOST=127.0.0.1
# BARCODE_PRINT_AGENT_PORT=18766
# BARCODE_PRINT_SUMATRA=C:\Program Files (x86)\SumatraPDF\SumatraPDF.exe
# BARCODE_PRINT_PRINTER=точное имя принтера из Windows

# Новая панель /warehouse: первый администратор создаётся при пустой таблице пользователей.
# Если WAREHOUSE_ADMIN_PASSWORD не задан, для входа используется WEB_DASHBOARD_SECRET.
WAREHOUSE_ADMIN_LOGIN=admin
WAREHOUSE_ADMIN_PASSWORD=change_me_warehouse_admin_password
# WAREHOUSE_ADMIN_DISPLAY_NAME=Администратор
# Bearer-токен внешнего API задач: GET/POST /api/v1/tasks/... (заголовок Authorization: Bearer …)
# WAREHOUSE_TASKS_API_TOKEN=change_me_tasks_api_token

# Анализ заказов дилера (/dealer-analysis): отдельная SQLite и каталог xlsx на диске.
DEALER_ANALYSIS_DB_URL=sqlite:///dealer_analysis.db
# DEALER_ANALYSIS_DATA_DIR=data/dealer_analysis
